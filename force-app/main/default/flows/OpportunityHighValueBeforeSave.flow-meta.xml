<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>60.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>Automatically sets the High Value Opportunity flag based on the Opportunity Amount. Sets to TRUE when Amount is greater than or equal to 100,000 USD, FALSE otherwise.</description>
    <formulas>
        <name>HighValueOpportunityFormula</name>
        <dataType>Boolean</dataType>
        <expression>IF(ISNULL({!$Record.Amount}), false, {!$Record.Amount} &gt;= 100000)</expression>
    </formulas>
    <label>Opportunity High Value Before Save</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>SetHighValueOpportunityFlag</name>
        <label>Set High Value Opportunity Flag</label>
        <locationX>176</locationX>
        <locationY>134</locationY>
        <inputAssignments>
            <field>HighValueOpportunity__c</field>
            <value>
                <elementReference>HighValueOpportunityFormula</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>SetHighValueOpportunityFlag</targetReference>
        </connector>
        <object>Opportunity</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
